#install.packages("tidyverse")
#install.packages("here")
library(here)
library(dplyr)
library(tidyverse)
library(ggplot2)
#Carga de Datos
if (!exists("df_ratings")) {
ruta_ratings <- here("XWines_Test_1K_ratings.csv")
df_ratings <- read.csv(ruta_ratings)
}
if (!exists("df_wines")) {
ruta_wines <- here("XWines_Test_100_wines.csv")
df_wines <- read.csv(ruta_wines)
}
#EDA
#Merge de Dataframes
df_completo <- merge(df_ratings, df_wines, by = "WineID")
#Eliminación de columnas que no utilizamos mediante select (librería dplyr)
df_completo <- df_completo %>% select(-RatingID, -UserID, -Date,
-WineryID, -WineryName, -Website,
-Vintages, -RegionID, -RegionName)
#Análisis de nulos
tabla_nulos <- data.frame(
Columna = names(df_completo),
Conteo_NA = colSums(is.na(df_completo)),
Proporcion = colMeans(is.na(df_completo))
)
#Combinamos "Dessert/Port" con "Dessert"
df_completo <- df_completo %>%
mutate(Type = ifelse(Type == "Dessert/Port", "Dessert", Type))
#Observamos la frecuencia para futura referencia
#Teóricamente al tener más observaciones los intervalos de confianza
#van a ser mejores para los tipos que tengamos más observaciones
frecuencias_por_tipo<- df_completo %>%
count(Type, name = "Frecuencia", sort = TRUE)
ggplot(df_completo, aes(x = Type, y = Rating, fill = Type)) +
geom_boxplot(alpha = 0.7) +
labs(
title = "Distribución de Calificaciones por Tipo de Vino",
x = "Tipo de Vino",
y = "Calificación (Rating)"
) +
theme_minimal() +
theme(legend.position = "none")
df_promedios_tipo <- df_completo %>%
group_by(Type) %>%
summarise(Rating_Promedio = mean(Rating)) %>%
arrange(desc(Rating_Promedio))
ggplot(df_promedios_tipo, aes(x = reorder(Type, -Rating_Promedio), y = Rating_Promedio, fill = Type)) +
geom_bar(stat = "identity", alpha = 0.8) +
labs(
title = "Rating Promedio por Tipo de Vino",
x = "Tipo de Vino",
y = "Promedio de Rating"
) +
theme_minimal() +
theme(legend.position = "none")
View(df_completo)
ggplot(df_completo, aes(x = ABV, y = Rating, color = Type)) +
geom_jitter(alpha = 0.5) + # jitter ayuda a ver puntos solapados
geom_smooth(method = "lm", se = FALSE) + # añade una línea de tendencia
labs(title = "Relación entre Alcohol (ABV) y Rating") +
theme_minimal()
# Tabla de frecuencias cruzadas (Parecido a lo que hiciste con vulnerabilidad y región)
tabla_alcohol_tipo <- df_completo %>%
count(Type, Nivel_Alcohol) %>%
group_by(Type) %>%
mutate(Prop = n / sum(n) * 100)
# Tabla de frecuencias cruzadas (Parecido a lo que hiciste con vulnerabilidad y región)
tabla_alcohol_tipo <- df_completo %>%
count(Type, ABV) %>%
group_by(Type) %>%
mutate(Prop = n / sum(n) * 100)
View(tabla_alcohol_tipo)
# Creamos categorías de alcohol (Binning)
df_completo <- df_completo %>%
mutate(Nivel_Alcohol = case_when(
ABV < 12 ~ "Bajo (<12%)",
ABV >= 12 & ABV <= 14.5 ~ "Moderado (12-14.5%)",
ABV > 14.5 ~ "Alto (>14.5%)"
))
# Tabla de frecuencias cruzadas (Parecido a lo que hiciste con vulnerabilidad y región)
tabla_alcohol_tipo <- df_completo %>%
count(Type, ABV) %>%
group_by(Type) %>%
mutate(Prop = n / sum(n) * 100)
View(tabla_alcohol_tipo)
View(df_wines)
# Tabla de frecuencias cruzadas (Parecido a lo que hiciste con vulnerabilidad y región)
tabla_alcohol_tipo <- df_completo %>%
count(Type, Nivel_Alcohol) %>%
group_by(Type) %>%
mutate(Prop = n / sum(n) * 100)
View(tabla_alcohol_tipo)
#install.packages("tidyverse")
#install.packages("here")
library(here)
library(dplyr)
library(tidyverse)
library(ggplot2)
#Carga de Datos
if (!exists("df_ratings")) {
ruta_ratings <- here("XWines_Test_1K_ratings.csv")
df_ratings <- read.csv(ruta_ratings)
}
if (!exists("df_wines")) {
ruta_wines <- here("XWines_Test_100_wines.csv")
df_wines <- read.csv(ruta_wines)
}
#EDA
#Merge de Dataframes
df_completo <- merge(df_ratings, df_wines, by = "WineID")
#Eliminación de columnas que no utilizamos mediante select (librería dplyr)
df_completo <- df_completo %>% select(-RatingID, -UserID, -Date,
-WineryID, -WineryName, -Website,
-Vintages, -RegionID, -RegionName)
#Análisis de nulos
tabla_nulos <- data.frame(
Columna = names(df_completo),
Conteo_NA = colSums(is.na(df_completo)),
Proporcion = colMeans(is.na(df_completo))
)
#Combinamos "Dessert/Port" con "Dessert"
df_completo <- df_completo %>%
mutate(Type = ifelse(Type == "Dessert/Port", "Dessert", Type))
#Observamos la frecuencia para futura referencia
#Teóricamente al tener más observaciones los intervalos de confianza
#van a ser mejores (más pequeños/precisos) para los tipos que tengamos más observaciones
frecuencias_por_tipo<- df_completo %>%
count(Type, name = "Frecuencia", sort = TRUE)
ggplot(df_completo, aes(x = Type, y = Rating, fill = Type)) +
geom_boxplot(alpha = 0.7) +
labs(
title = "Distribución de Calificaciones por Tipo de Vino",
x = "Tipo de Vino",
y = "Calificación (Rating)"
) +
theme_minimal() +
theme(legend.position = "none")
df_promedios_tipo <- df_completo %>%
group_by(Type) %>%
summarise(Rating_Promedio = mean(Rating)) %>%
arrange(desc(Rating_Promedio))
ggplot(df_promedios_tipo, aes(x = reorder(Type, -Rating_Promedio), y = Rating_Promedio, fill = Type)) +
geom_bar(stat = "identity", alpha = 0.8) +
labs(
title = "Rating Promedio por Tipo de Vino",
x = "Tipo de Vino",
y = "Promedio de Rating"
) +
theme_minimal() +
theme(legend.position = "none")
ggplot(df_completo, aes(x = ABV, y = Rating, color = Type)) +
geom_jitter(alpha = 0.5) + # jitter ayuda a ver puntos solapados
geom_smooth(method = "lm", se = FALSE) + # añade una línea de tendencia
labs(title = "Relación entre Alcohol (ABV) y Rating") +
theme_minimal()
df_completo <- df_completo %>%
mutate(Nivel_Alcohol = case_when(
ABV < 12 ~ "Bajo (<12%)",
ABV >= 12 & ABV <= 14.5 ~ "Moderado (12-14.5%)",
ABV > 14.5 ~ "Alto (>14.5%)",
TRUE ~ "Sin Datos"
))
# 2. Cálculo de proporciones por Tipo (Estilo PPDAC)
df_proporciones <- df_completo %>%
filter(Nivel_Alcohol != "Sin Datos") %>%
count(Type, Nivel_Alcohol) %>%
group_by(Type) %>%
mutate(Porcentaje = n / sum(n) * 100)
# 3. Gráfico de barras apiladas al 100%
ggplot(df_proporciones, aes(x = Type, y = Porcentaje, fill = Nivel_Alcohol)) +
geom_bar(stat = "identity", position = "fill") + # "fill" estira las barras al 100%
scale_y_continuous(labels = scales::percent) +
scale_fill_brewer(palette = "YlOrRd") + # Paleta de colores cálidos
labs(
title = "Distribución Proporcional de Niveles de Alcohol por Tipo de Vino",
subtitle = "Análisis de composición estructural según la categoría",
x = "Tipo de Vino",
y = "Proporción (%)",
fill = "Graduación (ABV)"
) +
theme_minimal()
#install.packages("tidyverse")
#install.packages("here")
library(here)
library(dplyr)
library(tidyverse)
library(ggplot2)
#Carga de Datos
if (!exists("df_ratings")) {
ruta_ratings <- here("XWines_Test_1K_ratings.csv")
df_ratings <- read.csv(ruta_ratings)
}
if (!exists("df_wines")) {
ruta_wines <- here("XWines_Test_100_wines.csv")
df_wines <- read.csv(ruta_wines)
}
#EDA
#Merge de Dataframes
df_completo <- merge(df_ratings, df_wines, by = "WineID")
#Eliminación de columnas que no utilizamos mediante select (librería dplyr)
df_completo <- df_completo %>% select(-RatingID, -UserID, -Date,
-WineryID, -WineryName, -Website,
-Vintages, -RegionID, -RegionName)
#Análisis de nulos
tabla_nulos <- data.frame(
Columna = names(df_completo),
Conteo_NA = colSums(is.na(df_completo)),
Proporcion = colMeans(is.na(df_completo))
)
#Combinamos "Dessert/Port" con "Dessert"
df_completo <- df_completo %>%
mutate(Type = ifelse(Type == "Dessert/Port", "Dessert", Type))
#Observamos la frecuencia para futura referencia
#Teóricamente al tener más observaciones los intervalos de confianza
#van a ser mejores (más pequeños/precisos) para los tipos que tengamos más observaciones
frecuencias_por_tipo<- df_completo %>%
count(Type, name = "Frecuencia", sort = TRUE)
ggplot(df_completo, aes(x = Type, y = Rating, fill = Type)) +
geom_boxplot(alpha = 0.7) +
labs(
title = "Distribución de Calificaciones por Tipo de Vino",
x = "Tipo de Vino",
y = "Calificación (Rating)"
) +
theme_minimal() +
theme(legend.position = "none")
df_promedios_tipo <- df_completo %>%
group_by(Type) %>%
summarise(Rating_Promedio = mean(Rating)) %>%
arrange(desc(Rating_Promedio))
ggplot(df_promedios_tipo, aes(x = reorder(Type, -Rating_Promedio), y = Rating_Promedio, fill = Type)) +
geom_bar(stat = "identity", alpha = 0.8) +
labs(
title = "Rating Promedio por Tipo de Vino",
x = "Tipo de Vino",
y = "Promedio de Rating"
) +
theme_minimal() +
theme(legend.position = "none")
ggplot(df_completo, aes(x = ABV, y = Rating, color = Type)) +
geom_jitter(alpha = 0.5) + # jitter ayuda a ver puntos solapados
geom_smooth(method = "lm", se = FALSE) + # añade una línea de tendencia
labs(title = "Relación entre Alcohol (ABV) y Rating") +
theme_minimal()
df_completo <- df_completo %>%
mutate(Nivel_Alcohol = case_when(
ABV < 12 ~ "Bajo (<12%)",
ABV >= 12 & ABV <= 14.5 ~ "Moderado (12-14.5%)",
ABV > 14.5 ~ "Alto (>14.5%)",
TRUE ~ "Sin Datos"
)) %>%
mutate(Nivel_Alcohol = factor(Nivel_Alcohol,
levels = c("Bajo (<12%)", "Moderado (12-14.5%)", "Alto (>14.5%)")))
# 2. Cálculo de proporciones (se mantiene igual)
df_proporciones <- df_completo %>%
filter(!is.na(Nivel_Alcohol)) %>%
count(Type, Nivel_Alcohol) %>%
group_by(Type) %>%
mutate(Porcentaje = n / sum(n) * 100)
# 3. Gráfico con la leyenda ordenada
ggplot(df_proporciones, aes(x = Type, y = Porcentaje, fill = Nivel_Alcohol)) +
geom_bar(stat = "identity", position = "fill") +
scale_y_continuous(labels = scales::percent) +
scale_fill_brewer(palette = "YlOrRd") +
labs(
title = "Distribución Proporcional de Niveles de Alcohol por Tipo de Vino",
subtitle = "Leyenda ordenada jerárquicamente",
x = "Tipo de Vino",
y = "Proporción (%)",
fill = "Graduación (ABV)"
) +
theme_minimal()
# 3. Gráfico con la leyenda ordenada
ggplot(df_proporciones, aes(x = Type, y = Porcentaje, fill = Nivel_Alcohol)) +
geom_bar(stat = "identity", position = "fill") +
scale_y_continuous(labels = scales::percent) +
scale_fill_brewer(palette = "YlOrRd") +
labs(
title = "Distribución Proporcional de Niveles de Alcohol por Tipo de Vino",
x = "Tipo de Vino",
y = "Proporción (%)",
fill = "Graduación (ABV)"
) +
theme_minimal()
View(df_ratings)
View(df_proporciones)
rm(df_ratings, df_wines)
View(df_proporciones)
View(tabla_nulos)
