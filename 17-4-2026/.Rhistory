install.packages("tidyverse")
library(here)
library(dplyr)
library(tidyverse)
#Carga de Datos
if (!exists("df_ratings")) {
ruta_ratings <- here("XWines_Test_1K_ratings.csv")
df_ratings <- read.csv(ruta_ratings)
}
if (!exists("df_wines")) {
ruta_wines <- here("XWines_Test_100_wines.csv")
df_wines <- read.csv(ruta_wines)
}
#EDA
#Merge de Dataframes
df_completo <- merge(df_ratings, df_wines, by = "WineID")
#Eliminación de columnas que no utilizamos mediante select (librería dplyr)
df_completo <- df_completo %>% select(-RatingID, -UserID, -Date,
-WineryID, -WineryName, -Website,
-Vintages, -RegionID, -RegionName)
tabla_nulos <- data.frame(
Columna = names(df_completo),
Conteo_NA = colSums(is.na(df_completo)),
Proporcion = colMeans(is.na(df_completo))
)
View(tabla_nulos)
View(df_wines)
View(df_completo)
View(df_completo)
View(df_completo)
length(unique(df_completo[["Country"]]))
unique(df_completo[["Country"]])
unique(df_completo[["Type"]])
# 1. Limpiamos y preparamos los datos
df_analisis <- df_completo %>%
# Agrupamos los vinos de postre
mutate(Type = ifelse(Type == "Dessert/Port", "Dessert", Type)) %>%
# Filtramos por si hay algún NA en Rating o Type
filter(!is.na(Rating), !is.na(Type))
# 2. Calculamos las estadísticas y el Intervalo de Confianza (95%)
tabla_ic <- df_analisis %>%
group_by(Type) %>%
summarise(
n = n(),
media = mean(Rating),
desvio = sd(Rating),
# Calculamos el error estándar y el margen de error (valor t para 95%)
error_estandar = desvio / sqrt(n),
margen_error = qt(0.975, df = n - 1) * error_estandar,
# Límites del intervalo
limite_inf = media - margen_error,
limite_sup = media + margen_error
) %>%
# Ordenamos de mayor a menor calificación media
arrange(desc(media))
print(tabla_ic)
# 3. Hacemos el Gráfico (Estilo TP2)
ggplot(tabla_ic, aes(x = reorder(Type, media), y = media)) +
geom_bar(stat = "identity", fill = "steelblue", width = 0.7) +
# Agregamos las "barritas" del intervalo de confianza
geom_errorbar(aes(ymin = limite_inf, ymax = limite_sup),
width = 0.2, color = "black") +
coord_flip() + # Lo acostamos para que se lea mejor, como en tu informe
labs(
title = "Calificación media por Tipo de Vino",
x = "Tipo de Vino",
y = "Calificación Media (Rating)"
) +
theme_minimal()
View(tabla_nulos)
frecuencias_por_tipo <- df_completo %>%
group_by(Type) %>%
summarise(
Frecuencia = n() # n() cuenta la cantidad de filas por grupo
) %>%
arrange(desc(Frecuencia)) # Opcional: lo ordenamos de mayor a menor
print(frecuencias_por_tipo)
#Combinamos "Dessert/Port" a "Dessert"
df_analisis <- df_completo %>%
mutate(Type = ifelse(Type == "Dessert/Port", "Dessert", Type))
frecuencias_por_tipo <- df_completo %>%
group_by(Type) %>%
summarise(
Frecuencia = n() # n() cuenta la cantidad de filas por grupo
) %>%
arrange(desc(Frecuencia)) # Opcional: lo ordenamos de mayor a menor
print(frecuencias_por_tipo)
#Combinamos "Dessert/Port" a "Dessert"
df_analisis <- df_completo %>%
mutate(Type = ifelse(Type == "Dessert/Port", "Dessert", Type))
frecuencias_por_tipo <- df_analisis %>%
group_by(Type) %>%
summarise(
Frecuencia = n() # n() cuenta la cantidad de filas por grupo
) %>%
arrange(desc(Frecuencia)) # Opcional: lo ordenamos de mayor a menor
print(frecuencias_por_tipo)
